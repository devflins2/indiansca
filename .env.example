# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/media_bot?retryWrites=true&w=majority

# Telegram API Credentials (from https://my.telegram.org/apps)
API_ID=12345678
API_HASH=your_api_hash_here

# Telegram Group/Channel ID (negative number for groups)
GROUP_ID=-1001234567890

# Telegram Session String (generated via npm run auth)
SESSION_STRING=

# Optional overrides
MAX_VIDEOS_PER_DAY=50
DELAY_BETWEEN_SENDS=20
DELAY_BETWEEN_PAGES=30
DELAY_BETWEEN_API_CALLS=3
PORT=3000

# Optional HTTP/HTTPS/SOCKS proxy (e.g. http://127.0.0.1:8080)
PROXY_URL=

# Indian and Desi keywords for search rotation (comma-separated)
KEYWORDS=indian,desi,bhabhi,hindi,pakistani,bhojpuri,tamil,telugu,mallu,kerala,punjabi,marathi,bengali,bangla,aunty,gujarati,kannada,nepali,devar,indian bhabhi,desi bhabhi

# Provider API endpoints (fill with the actual URLs - never pushed to GitHub)
API_BASE_URL=https://provider.example.com/api/v2/video/search/
API_DETAIL_URL=https://provider.example.com/api/v2/video/id/
API_REFERER=https://provider.example.com/
API_VIDEO_PAGE=https://provider.example.com/video-